{
    "name": "@steel-dev/mcp-server",
    "version": "0.0.1",
    "description": "MCP server for browser automation using Steel and Playwright (via Beam)",
    "license": "MIT",
    "author": "Steel (https://steel.dev)",
    "homepage": "https://steel.dev",
    "bugs": "https://github.com/steel-dev/mcp-server/issues",
    "type": "module",
    "bin": {
        "mcp-server-steel": "dist/index.cjs"
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsup src/index.ts --out-dir dist",
        "dev": "tsx --watch src/index.ts",
        "watch": "tsup src/index.ts --out-dir dist --watch",
        "start": "node dist/index.cjs",
        "inspector": "npx @modelcontextprotocol/inspector fnm exec --using=22 tsx --watch src/index.ts"
    },
    "dependencies": {
        "@ai-sdk/anthropic": "^1.2.11",
        "@ai-sdk/openai": "^1.3.22",
        "@modelcontextprotocol/sdk": "^1.11.3",
        "beam": "^0.7.0",
        "dotenv": "^16.5.0",
        "steel-sdk": "^0.2.0",
        "zod": "^3.24.4"
    },
    "devDependencies": {
        "@modelcontextprotocol/inspector": "^0.12.0",
        "shx": "^0.3.4",
        "tsup": "^8.4.0",
        "tsx": "^4.19.4",
        "typescript": "^5.6.2"
    }
}
