{
    "name": "@steel-dev/mcp-server",
    "version": "0.0.1",
    "description": "MCP server for browser automation using Steel and Playwright",
    "license": "MIT",
    "author": "Steel (https://steel.dev)",
    "homepage": "https://steel.dev",
    "bugs": "https://github.com/steel-dev/mcp-server/issues",
    "type": "module",
    "bin": {
        "mcp-server-steel": "dist/index.cjs"
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsup src/index.ts --out-dir dist",
        "dev": "tsx --watch src/index.ts",
        "watch": "tsup src/index.ts --out-dir dist --watch",
        "start": "node dist/index.cjs",
        "inspector": "npx @modelcontextprotocol/inspector fnm exec --using=22 tsx --watch src/index.ts"
    },
    "pnpm": {
        "nodeLinker": "hoisted"
    },
    "dependencies": {
        "@modelcontextprotocol/sdk": "^1.29.0",
        "dotenv": "^17.3.1",
        "playwright": "^1.58.2",
        "steel-sdk": "^0.18.0",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@modelcontextprotocol/inspector": "^0.21.1",
        "shx": "^0.4.0",
        "tsup": "^8.5.1",
        "tsx": "^4.21.0",
        "typescript": "^6.0.2"
    }
}
